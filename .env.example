# ==============================================================================
# GISEC Platform Environment Variables Configuration Template
# Duplicate this file to '.env.local' and fill in your actual credentials.
# ==============================================================================

# NEXT.JS CORE CONFIGURATION
NEXT_PUBLIC_APP_URL=http://localhost:3000

# DATABASE CONNECTIONS (Supabase / Neon Postgres)
# PostgreSQL connection string used for server-side queries and database migrations
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres?sslmode=require"

# SUPABASE CLIENT CREDENTIALS (Authentication & Database Client APIs)
# Public API key safe to expose on the client browser
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-ID].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
# Secret Service Role Key - NEVER expose to client browser. Used for Admin overrides.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# PAYMENT GATEWAYS (Paystack / Flutterwave credentials)
# Public keys used on checkout pages, secret keys used for API verification on server
PAYSTACK_PUBLIC_KEY="pk_test_..."
PAYSTACK_SECRET_KEY="sk_test_..."
PAYSTACK_WEBHOOK_SECRET="whsec_..."

FLUTTERWAVE_PUBLIC_KEY="FLWPUBK_TEST-..."
FLUTTERWAVE_SECRET_KEY="FLWSECK_TEST-..."
FLUTTERWAVE_HASH_TOKEN="gisec_flw_hash_12345"

# EMAIL TRANSACTIONAL API (Resend / SendGrid credentials)
# Used to dispatch verification emails, cohort welcome guides, and live session updates
EMAIL_API_KEY="re_..."
EMAIL_FROM_ADDRESS="no-reply@gisec.africa"

# SECURITY KEYS
# Used for custom JWT tokens or cookie signing
NEXTAUTH_SECRET="your_nextauth_jwt_secret_signing_key_here"
